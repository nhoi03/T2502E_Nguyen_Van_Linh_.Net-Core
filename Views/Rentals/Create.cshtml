<h2>Create Rental</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label>Customer</label>
        <select name="customerId" class="form-control" asp-items="ViewBag.Customers"></select>
    </div>

    <div class="mb-3">
        <label>Rental Date</label>
        <input type="date" name="rentalDate" class="form-control" required/>
    </div>

    <div class="mb-3">
        <label>Return Date</label>
        <input type="date" name="returnDate" class="form-control" required/>
    </div>

    <div class="mb-3">
        <label>Comic Book</label>
        <select name="comicBookId" class="form-control" asp-items="ViewBag.ComicBooks"></select>
    </div>

    <div class="mb-3">
        <label>Quantity</label>
        <input type="number" name="quantity" class="form-control" value="1" min="1" required/>
    </div>

    <button class="btn btn-primary">Save Rental</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</form>